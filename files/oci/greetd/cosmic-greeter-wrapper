#!/bin/sh
# Drop-in replacement for upstream's /usr/bin/cosmic-greeter-start.
#
# Differences vs upstream:
#   - Uses absolute paths everywhere. greetd's session PATH does not
#     include /usr/bin reliably; cosmic-comp's kiosk-child exec'd
#     `cosmic-greeter` (relative) and got ENOENT. Spelling out
#     /usr/bin/cosmic-greeter avoids the lookup.
#   - Sends stdout + stderr to the journal (tagged) instead of
#     /dev/null. Upstream's wrapper redirects everything to /dev/null
#     which made the ENOENT invisible (and cost a debug cycle).
#
# Installed at /usr/local/bin/cosmic-greeter-wrapper and referenced
# from /etc/greetd/config.toml so it takes precedence over the
# upstream binary in /usr/bin/.
rm -rf /run/cosmic-greeter/cosmic/com.system76.CosmicSettingsDaemon/v1/* >/dev/null 2>&1
exec /usr/bin/systemd-cat -t cosmic-greeter-session \
    /usr/bin/cosmic-comp /usr/bin/cosmic-greeter
