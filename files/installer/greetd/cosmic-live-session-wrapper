#!/bin/sh
# Live env session entry. Mirror of cosmic-greeter-wrapper's structure
# but launches the regular COSMIC session (not the greeter kiosk).
#
# Installed at /usr/local/bin/cosmic-live-session-wrapper; referenced
# from /etc/greetd/config.toml's [initial_session] in the Live env.
#
# After the session is up, the autostart .desktop in
# /etc/xdg/autostart/ triggers cosmonaut-installer (the libcosmic
# install GUI shipped via installer/cosmonaut-installer.bst).

# Keep the live session as close as possible to a normal COSMIC desktop
# launch. greetd still provides the live-only autologin user; start-cosmic
# provides the upstream session environment and starts cosmic-session.
exec /usr/bin/start-cosmic
